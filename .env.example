# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Required to fetch CMS content. Without these, all pages fall back to
# hardcoded data — the site still builds and runs correctly.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Umami Analytics ─────────────────────────────────────────────────────────
# Cookie-free, self-hosted analytics. Script loaded via next/script afterInteractive.
# Without these, no analytics script is injected — no console errors.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-host.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ─── Resend (transactional email) ────────────────────────────────────────────
# Used by /api/contact (enquiry form) and /api/subscribe (newsletter).
# Without RESEND_API_KEY the API routes return a 500 error at send time.
RESEND_API_KEY=
RESEND_TO_EMAIL=adminpang@digisci.solutions
# Optional: Resend audience ID for newsletter subscriber list management.
# When set, subscribers are added to this Resend Contacts audience on sign-up.
RESEND_AUDIENCE_ID=
